{
  "manifest_version": 3,
  "name": "Vault — Password Generator",
  "version": "1.0.0",
  "description": "Generate insane passwords, autofill them anywhere, and store them safely.",
  "homepage_url": "https://djxdtho.github.io/password-generator/",
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-16.svg",
    "128": "icons/icon-16.svg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vault — Generate Password",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-16.svg",
      "128": "icons/icon-16.svg"
    }
  },
  "permissions": [
    "clipboardWrite",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open Vault password generator"
    }
  }
}
